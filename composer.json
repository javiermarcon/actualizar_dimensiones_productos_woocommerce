{
    "name": "javier/actualizar-dimensiones-productos-woocommerce",
    "type": "wordpress-plugin",
    "require": {
        "phpoffice/phpspreadsheet": "^4.0"
    },
    "require-dev": {
        "phpstan/phpstan": "^1.12",
        "phpunit/phpunit": "^12.0",
        "squizlabs/php_codesniffer": "^3.10"
    },
    "scripts": {
        "hooks:install": "bash scripts/install-git-hooks.sh",
        "lint:php": "bash scripts/lint-staged-php.sh --all",
        "lint:phpcs": "bash scripts/lint-staged-phpcs.sh --all",
        "lint:phpstan": "bash scripts/lint-staged-phpstan.sh --all",
        "lint": [
            "@lint:php",
            "@lint:phpcs",
            "@lint:phpstan"
        ],
        "test": "phpunit --configuration=phpunit.xml.dist",
        "test:coverage": "XDEBUG_MODE=coverage phpunit --configuration=phpunit.xml.dist --coverage-text --coverage-html build/coverage"
    },
    "config": {
        "sort-packages": true
    }
}
